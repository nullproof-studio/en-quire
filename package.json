  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "better-sqlite3": "^11.9.1",
    "diff": "^7.0.0",
    "micromatch": "^4.0.8",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "simple-git": "^3.27.0",
    "unified": "^11.0.5",
    "winston": "^3.19.0",
    "yaml": "^2.7.1",
    "zod": "^3.24.4"
  },

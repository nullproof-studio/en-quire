{
  "name": "@nullproof-studio/en-quire",
  "version": "0.1.0",
  "description": "Structured markdown document management for agent systems, with governance. An MCP server.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "enquire": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
